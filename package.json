{
  "name": "bacalah-nichesite",
  "version": "1.0.0",
  "private": true,
  "description": "Static niche site for Think Quran affiliate marketing",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/tailwind.min.css --minify",
    "build:site": "cp ./src/site.css ./dist/site.css",
    "build:sitemap": "node ./scripts/build-sitemap.js",
    "build": "npm run build:css && npm run build:site && npm run build:sitemap",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/tailwind.min.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "3.4.1"
  }
}
